#!/usr/bin/env ruby
#MISE description="SSH 터널 + Sequel IRB 세션"
#MISE alias="db:irb"

require 'bundler/inline'
gemfile do
  source 'https://rubygems.org'
  gem 'sequel'
  gem 'pg'
  gem 'irb'
end

require 'uri'
require 'socket'

# 사용법:
#   mise run db:irb <ssh-host> <postgres-url>          # SSH 터널 사용
#   mise run db:irb <ssh-host> <postgres-url> --write  # prod에서 쓰기 허용
#   mise run db:irb - <postgres-url>                   # 로컬 직접 연결
#   mise run db:irb <postgres-url>                     # 로컬 직접 연결 (단축)
#   mise run db:irb - <postgres-url> -e 'User.first'   # 코드 실행 후 종료

# -e 옵션 파싱 (다른 옵션보다 먼저)
exec_code = nil
if (idx = ARGV.index('-e'))
  exec_code = ARGV[idx + 1]
  ARGV.delete_at(idx + 1)
  ARGV.delete_at(idx)
end

write_mode = ARGV.delete('--write')

if ARGV[0]&.start_with?('postgres')
  ssh_target = nil
  db_url = ARGV[0]
else
  ssh_target = ARGV[0] == '-' ? nil : ARGV[0]
  db_url = ARGV[1]
end

abort "Usage: mise run db:irb [ssh-host|-] <postgres-url> [--write]" unless db_url

# Password escape 필요 여부 판단
def needs_escape?(password)
  return false if password.nil? || password.empty?
  # 이미 %XX 형태가 있으면 encoded로 간주
  return false if password.match?(/%[0-9A-Fa-f]{2}/)
  # 특수문자가 있으면 escape 필요
  password.match?(/[^a-zA-Z0-9._~-]/)
end

uri = URI.parse(db_url)
abort "Invalid database URL" unless uri.host

# escape 안 된 password 자동 처리
if needs_escape?(uri.password)
  uri.password = URI.encode_www_form_component(uri.password)
  db_url = uri.to_s
end

local_port = uri.port || 5432

# localhost를 127.0.0.1로 변환 (IPv6 문제 방지)
connect_host = uri.host == 'localhost' ? '127.0.0.1' : uri.host

if ssh_target
  # SSH 터널 시작 (SSH config의 LocalForward 사용)
  pid = spawn("ssh", "-N", ssh_target)

  cleanup = -> { Process.kill('TERM', pid) rescue nil }
  at_exit(&cleanup)
  trap('INT') { cleanup.call; exit 130 }

  # 터널 연결 대기 (최대 10초)
  connected = false
  10.times do
    begin
      TCPSocket.new(connect_host, local_port).close
      connected = true
      break
    rescue Errno::ECONNREFUSED
      sleep 1
    end
  end
  abort "SSH 터널 연결 실패" unless connected
end

# DB 연결 (URL 직접 치환 - URI 파싱의 encoding 문제 방지)
db_connect_url = db_url.sub("@#{uri.host}:", "@#{connect_host}:")
DB = Sequel.connect(db_connect_url)

# Raw SQL 차단: DB["SELECT ..."] 대신 Sequel DSL 사용 유도
class << DB
  alias_method :_orig_bracket, :[]

  def [](*args)
    if args.first.is_a?(String)
      puts "\e[31m✗ Raw SQL은 차단되어 있습니다. Sequel DSL을 사용하세요.\e[0m"
      puts "\e[36m  예시:\e[0m"
      puts "    User.where(id: 1).all          # SELECT * FROM users WHERE id = 1"
      puts "    User.where { age > 20 }.all    # SELECT * FROM users WHERE age > 20"
      puts "    User.select(:id, :name).all    # SELECT id, name FROM users"
      puts "    raw_sql(\"SELECT ...\")           # 명시적 raw SQL 실행"
      puts ""
      return nil
    end
    _orig_bracket(*args)
  end
end

def raw_sql(sql, *bind)
  DB._orig_bracket(sql, *bind)
end

# prod는 기본 읽기 전용 (--write로 해제)
is_prod = ssh_target.to_s.match?(/prod/i)
readonly = is_prod && !write_mode
READONLY = readonly  # import 함수에서 참조
WRITE_SAFE = write_mode && !readonly && !exec_code

def write_check
  if READONLY
    puts "\e[31mRead-only mode. Restart with --write\e[0m"
    return :readonly
  end
  WRITE_SAFE ? :safe : :direct
end

if readonly
  DB.run("SET default_transaction_read_only = on")
end

# Safe Write: pending 참조 + WriteGuard + print_table
$_pending_change = nil
def pending; $_pending_change; end

WRITE_GUARDS = {}
def write_guard(table, &block)
  (WRITE_GUARDS[table.to_sym] ||= []) << block
end
WriteContext = Struct.new(:operation, :count, :values, :dataset, :before, keyword_init: true)

REVERSE_FK_MAP = Hash.new { |h, k| h[k] = [] }

def print_table(rows, indent: 0)
  return puts "#{"  " * indent}No rows" if rows.empty?
  cols = rows.first.keys
  widths = cols.map { |c| [c.to_s.length, rows.map { |r| r[c].to_s.length }.max].max }
  prefix = "  " * indent
  puts prefix + cols.zip(widths).map { |c, w| c.to_s.ljust(w) }.join("  ")
  puts prefix + widths.map { |w| "-" * w }.join("  ")
  rows.each { |r| puts prefix + cols.zip(widths).map { |c, w| r[c].to_s.ljust(w) }.join("  ") }
end

# Sequel::Model 확장 (scope DSL + YAML export + normalizes)
Sequel::Model.plugin :validation_helpers

class Sequel::Model
  def self.normalizes(field, with:)
    (@_normalizers ||= {})[field] = with
  end

  def self.normalizers
    @_normalizers || {}
  end

  def self.apply_normalizers(values)
    return values unless @_normalizers
    values.each_with_object({}) do |(k, v), h|
      normalizer = @_normalizers[k]
      h[k] = normalizer ? normalizer.call(v) : v
    end
  end

  def self.scope(name, body)
    define_singleton_method(name) { |*args| dataset.instance_exec(*args, &body) }
  end

  def self.default_scope(&block)
    set_dataset(dataset.instance_exec(&block))
  end

  def to_yaml(path = nil)
    require 'yaml'
    yaml = self.values.to_yaml
    path ? (File.write(File.expand_path(path), yaml); puts "Saved to #{path}") : puts(yaml)
  end

  def self.joins(*assocs)
    assocs.reduce(dataset) { |ds, a| ds.association_join(a) }
  end

  def self.left_joins(*assocs)
    assocs.reduce(dataset) { |ds, a| ds.association_left_join(a) }
  end

  def self.where(*conds, &block)
    ds = dataset
    conds.each do |c|
      next unless c.is_a?(Hash)
      c.each_key do |k|
        next unless c[k].is_a?(Hash)
        assoc_name = association_reflections.keys.find do |name|
          association_reflection(name).associated_class.table_name == k rescue false
        end
        ds = ds.association_join(assoc_name) if assoc_name
      end
    end
    ds.where(*conds, &block)
  end

  # Safe Write: Model instance update/delete override
  alias_method :_orig_update, :update
  alias_method :_orig_delete, :delete

  def update(values = {})
    case write_check
    when :readonly then nil
    when :direct then _orig_update(values)
    when :safe then PendingChange.new(self, :update, values, before: self.values.dup)
    end
  end

  def update!(values = {})
    _orig_update(values)
  end

  def delete
    case write_check
    when :readonly then nil
    when :direct then _orig_delete
    when :safe then PendingChange.new(self, :delete, nil, before: self.values.dup)
    end
  end

  def delete!
    _orig_delete
  end
end

# Safe Write: PendingChange (preview → confirm → execute)
class PendingChange
  attr_reader :count, :operation

  def initialize(source, operation, values = nil, before: nil)
    @source = source
    @operation = operation
    @before = before
    @single = source.is_a?(Sequel::Model)
    @blocked = false
    @cascade_total = 0

    if @single
      @count = 1
      @table = source.class.table_name
      @dataset = source.this
      @model_class = source.class
    else
      @count = source.count
      @table = source.first_source_table rescue :unknown
      @dataset = source
      @model_class = table_to_class(@table) rescue nil
    end

    # normalizes 적용 (update만)
    if @operation == :update && values
      @values = @model_class ? @model_class.apply_normalizers(values) : values
      @normalized = values.keys.select { |k| @values[k] != values[k] }
    else
      @values = values
      @normalized = []
    end

    # validates 실행 (단건 update만)
    if @single && @operation == :update
      test_model = @source.class.load(@source.values.merge(@values))
      unless test_model.valid?
        @blocked = true
        @errors = test_model.errors
      end
    end

    run_guards
    print_preview
    $_pending_change = self
  end

  def apply!
    if @blocked
      puts "\e[31mBlocked: validation failed. Fix values and retry.\e[0m"
      @errors&.each { |col, msgs| msgs.each { |m| puts "  #{col}: #{m}" } }
      return nil
    end

    current = @dataset.count
    if current != @count
      puts "\e[33mWarning: count changed #{@count} -> #{current}\e[0m"
    end

    result = case @operation
    when :update
      @single ? @source._orig_update(@values) : @dataset._sequel_update(@values)
    when :delete
      @single ? @source._orig_delete : @dataset._sequel_delete
    end

    rows = case result
           when Integer then result
           when Sequel::Model then 1
           else @count
           end
    puts "\e[32m[DONE] #{op_name} #{rows} rows\e[0m"
    log_change(rows)
    result
  end

  def inspect
    status = @blocked ? " [BLOCKED]" : ""
    cascade = @cascade_total > 0 ? " (+ #{@cascade_total} cascade)" : ""
    "#<PendingChange #{op_name} #{@count} rows#{cascade}#{status} — _.apply! or pending.apply!>"
  end
  alias to_s inspect

  private

  def op_name = @operation == :update ? 'UPDATE' : 'DELETE'

  def run_guards
    guards = WRITE_GUARDS[@table] || []
    ctx = WriteContext.new(
      operation: @operation, count: @count,
      values: @values, dataset: @dataset, before: @before
    )
    guards.each do |guard|
      msg = guard.call(ctx)
      puts "\e[33m#{msg}\e[0m" if msg.is_a?(String)
    end
  end

  def print_preview
    if @single && @operation == :update && @before
      puts "\e[36m[PREVIEW] UPDATE #{@table} WHERE #{pk_desc}\e[0m"
      @values.each do |col, new_val|
        old_val = @before[col]
        norm = @normalized.include?(col) ? " \e[35m(normalized)\e[0m" : ""
        marker = old_val == new_val ? " " : "\e[33m*\e[0m"
        puts "  #{marker} #{col}: #{old_val.inspect} → #{new_val.inspect}#{norm}"
      end
    elsif @single && @operation == :delete
      puts "\e[36m[PREVIEW] DELETE #{@table} WHERE #{pk_desc}\e[0m"
      puts "  #{@before.inspect}" if @before
      print_cascade
    else
      puts "\e[36m[PREVIEW] #{op_name} #{@table} — #{@count} rows affected\e[0m"
      if @operation == :update && @values
        puts "  Changes: #{@values.map { |k, v| "#{k} → #{v.inspect}" }.join(', ')}"
      end
      sample = @dataset.limit(3).all
      unless sample.empty?
        puts "  Sample:"
        rows = sample.map { |r| r.respond_to?(:values) ? r.values : r }
        print_table(rows, indent: 2)
      end
      print_cascade if @operation == :delete
    end

    if @blocked && @errors
      puts "\e[31m✗ Validation failed:\e[0m"
      @errors.each { |col, msgs| msgs.each { |m| puts "  #{col}: #{m}" } }
    end
  end

  def print_cascade
    refs = REVERSE_FK_MAP[@table] || []
    return if refs.empty?

    cascade_refs = refs.select { |r| r[:on_delete] == :cascade }
    set_null_refs = refs.select { |r| r[:on_delete] == :set_null }

    if cascade_refs.any?
      puts "  \e[31m⚠ CASCADE:\e[0m"
      cascade_refs.each do |ref|
        cnt = DB[ref[:from_table]].where(ref[:column] => @dataset.select(pk_column)).count
        @cascade_total += cnt
        puts "    #{ref[:from_table]} (#{ref[:column]}) — #{cnt} rows will be deleted" if cnt > 0
      end
    end

    if set_null_refs.any?
      puts "  \e[33m⚠ SET NULL:\e[0m"
      set_null_refs.each do |ref|
        cnt = DB[ref[:from_table]].where(ref[:column] => @dataset.select(pk_column)).count
        puts "    #{ref[:from_table]} (#{ref[:column]}) — #{cnt} rows will be set to NULL" if cnt > 0
      end
    end
  end

  def pk_column
    @source.is_a?(Sequel::Model) ? @source.class.primary_key : :id
  end

  def pk_desc
    @source.is_a?(Sequel::Model) ? @source.pk_hash.map { |k, v| "#{k} = #{v}" }.join(', ') : "..."
  end

  def log_change(affected_rows)
    require 'json'
    require 'fileutils'
    log_dir = File.join(ENV['MISE_PROJECT_ROOT'] || ENV['PWD'] || Dir.pwd, 'tmp', 'db-irb-changes')
    FileUtils.mkdir_p(log_dir)
    log_file = File.join(log_dir, "#{Date.today}.jsonl")

    entry = {
      at: Time.now.iso8601,
      table: @table.to_s,
      operation: @operation,
      affected: affected_rows,
      values: @values,
      before: @before,
      where: @single ? pk_desc : @dataset.select_sql
    }
    File.open(log_file, 'a') { |f| f.puts JSON.generate(entry) }
  rescue => e
    puts "\e[33mWarning: failed to log change: #{e.message}\e[0m"
  end
end

class Sequel::Dataset
  alias_method :_sequel_where, :where
  def where(*conds, &block)
    _sequel_where(*conds.map { |c|
      next c unless c.is_a?(Hash)
      c.each_with_object({}) do |(k, v), h|
        if v.is_a?(Hash)
          v.each { |col, val| h[Sequel[k][col]] = val }
        else
          h[k] = v
        end
      end
    }, &block)
  end
  def joins(*assocs)
    assocs.reduce(self) { |ds, a| ds.association_join(a) }
  end
  def left_joins(*assocs)
    assocs.reduce(self) { |ds, a| ds.association_left_join(a) }
  end
  def to_yaml(path = nil)
    require 'yaml'
    data = self.all
    yaml = data.to_yaml
    path ? (File.write(File.expand_path(path), yaml); puts "Saved to #{path} (#{data.size} rows)") : puts(yaml)
  end

  # Safe Write: Dataset batch update/delete override
  alias_method :_sequel_update, :update
  alias_method :_sequel_delete, :delete

  def update(values = nil)
    case write_check
    when :readonly then nil
    when :direct then _sequel_update(values)
    when :safe then PendingChange.new(self, :update, values)
    end
  end

  def update!(values)
    _sequel_update(values)
  end

  def delete
    case write_check
    when :readonly then nil
    when :direct then _sequel_delete
    when :safe then PendingChange.new(self, :delete)
    end
  end

  def delete!
    _sequel_delete
  end
end

# 테이블별 Model 클래스 자동 생성
DB.tables.each do |table_name|
  begin
    class_name = table_name.to_s.split('_').map(&:capitalize).join
    Object.const_set(class_name, Class.new(Sequel::Model(table_name))) unless Object.const_defined?(class_name)
  rescue
    # schema_migrations 등 모델화 불가능한 테이블 무시
  end
end

# FK 기반 자동 association 설정 (belongs_to + has_many)
def table_to_class(table_name)
  Object.const_get(table_name.to_s.split('_').map(&:capitalize).join)
rescue NameError
  nil
end

DB.tables.each do |table_name|
  model = table_to_class(table_name)
  next unless model

  DB.foreign_key_list(table_name).each do |fk|
    # REVERSE_FK_MAP 구축 (CASCADE/SET NULL 감지용)
    REVERSE_FK_MAP[fk[:table]] << {
      from_table: table_name,
      column: fk[:columns].first,
      on_delete: fk[:on_delete]
    }

    assoc_name = fk[:columns].first.to_s.sub(/_id$/, '').to_sym
    ref_class = table_to_class(fk[:table])
    next unless ref_class
    model.many_to_one assoc_name, class: ref_class  # belongs_to
    # 동일 테이블 다중 FK 충돌 방지: 이미 등록된 이름이면 _as_{assoc} 접미사
    reverse_name = ref_class.associations.include?(table_name) ?
      :"#{table_name}_as_#{assoc_name}" : table_name
    ref_class.one_to_many reverse_name, class: model, key: fk[:columns].first  # has_many
  end
end

# FK alias 매핑 (creator_id -> member 등 비표준 FK명 지원)
FK_ALIAS_MAP = {}
def fk_alias(mappings)
  FK_ALIAS_MAP.merge!(mappings.transform_keys(&:to_sym).transform_values(&:to_sym))
  mappings.each do |alias_name, target_table|
    ref_class = table_to_class(target_table)
    next unless ref_class
    DB.tables.each do |t|
      model = table_to_class(t)
      next unless model
      col = :"#{alias_name}_id"
      next unless model.columns.include?(col)
      next if model.associations.include?(alias_name.to_sym)
      model.many_to_one alias_name.to_sym, class: ref_class, key: col
      ref_class.one_to_many :"#{t}_as_#{alias_name}", class: model, key: col
    end
  end
end

# _id 컬럼 기반 추론 (FK 없는 경우 fallback)
all_tables = DB.tables.map(&:to_s)
DB.tables.each do |table_name|
  model = table_to_class(table_name)
  next unless model

  DB[table_name].columns.each do |col|
    col_s = col.to_s
    next unless col_s.end_with?('_id')
    assoc_name = col_s.sub(/_id$/, '')
    next if model.associations.include?(assoc_name.to_sym)  # 이미 FK로 설정됨

    # 테이블명 추론: user -> users, category -> categories
    ref_table = all_tables.find do |t|
      t == "#{assoc_name}s" || t == "#{assoc_name}es" ||
      t == assoc_name.sub(/y$/, 'ies') || t == assoc_name
    end
    ref_class = table_to_class(ref_table) if ref_table
    next unless ref_class

    model.many_to_one assoc_name.to_sym, class: ref_class, key: col
    # 동일 테이블 다중 FK 충돌 방지
    reverse_name = ref_class.associations.include?(table_name) ?
      :"#{table_name}_as_#{assoc_name}" : table_name
    ref_class.one_to_many reverse_name, class: model, key: col
  end
end

# Soft delete 헬퍼 (deleted_at IS NULL 자동 적용)
def enable_soft_delete(*models)
  targets = models.empty? ?
    DB.tables.map { |t| table_to_class(t) }.compact :
    models
  count = 0
  targets.each do |m|
    next unless m.columns.include?(:deleted_at)
    m.default_scope { where(deleted_at: nil) }
    count += 1
  end
  puts "Soft delete enabled for #{count} models (use .unfiltered to bypass)"
end

