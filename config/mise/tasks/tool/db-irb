exec_code = nil
if (idx = ARGV.index('-e'))
  exec_code = ARGV[idx + 1]
  ARGV.delete_at(idx + 1)
  ARGV.delete_at(idx)
end

write_mode = ARGV.delete('--write')

if ARGV[0]&.start_with?('postgres')
  ssh_target = nil
  db_url = ARGV[0]
else
  ssh_target = ARGV[0] == '-' ? nil : ARGV[0]
  db_url = ARGV[1]
end

