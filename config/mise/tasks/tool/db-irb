def help(topic = nil)
  if topic
    key = topic.to_s.downcase.to_sym
    key = HELP_ALIASES[key] || key
    if HELP_TOPICS[key]
      puts HELP_TOPICS[key]
    else
      puts "Unknown topic: #{topic}"
      puts "Available: #{HELP_TOPICS.keys.join(', ')}"
    end
  else
    puts "== db-irb Quick Reference ==\n\n"
    HELP_TOPICS.each_value { |v| puts v }
    puts "\nTip: help :topic (e.g. help :like, help :join, help :where)"
  end
end

