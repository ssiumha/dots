snippet docker_stack_full_deploy "rolling update all services in Docker Swarm"
#!/bin/bash
set -e

REGISTRY="registry.example.com"
SERVICES=(auth members homepage api)

for svc in "${SERVICES[@]}"; do
  printf "\e[1;32mDeploying %s $(date +'%Y-%m-%d %H:%M:%S')\e[0m\n" "$svc"
  docker pull "$REGISTRY/$svc:latest"
  docker service update \
    --force \
    --update-parallelism 1 \
    --update-delay 10s \
    "stack_$svc"
  docker ps -a --filter "status=exited" -q | xargs -r docker rm
  docker image prune -f
done
endsnippet

snippet nextjs_action_generator "scaffold Next.js Server Action (clean architecture)"
#!/bin/bash
proj=$1; action=$2
action_dir="apps/$proj/src/server/action/$action"
mkdir -p "$action_dir"

pascal=$(echo "$action" | perl -pe 's/(^[a-z]|-([a-z]))/\U$1/g')
camel=$(echo "$action" | perl -pe 's/(-([a-z]))/\U$1/g')
prefix="@${proj}/server/action/${action}/${action}"

# Generates: .action.ts .request.ts .response.ts .use-case.ts .use-case.spec.ts
# Pattern: Zod validation → UseCase (DI container) → Response DTO
cat > "$action_dir/$action.action.ts" <<-EOF
'use server'
import { ${pascal}UseCase } from '${prefix}.use-case'
import { getUseCase } from '@${proj}/server/provider/container'
import { z } from 'zod'
import { redirect } from 'next/navigation'

const schema = z.object({ name: z.string({ required_error: 'required' }) })

export async function ${camel}Action(prevState: string | undefined, formData: FormData) {
  try {
    const req = schema.parse(Object.fromEntries(formData.entries()))
    await getUseCase(${pascal}UseCase).execute(req)
  } catch (e) {
    if (e instanceof z.ZodError) return e.issues.map(i => i.message)
    return ['Unknown error']
  }
  redirect('/')
}
EOF
endsnippet

snippet ubuntu_deb_archive "download deb packages for offline install"
#!/usr/bin/env bash
set -euxo pipefail

target_dir="./archives/debs"
cache_dir="./.cache"
mkdir -p "$target_dir" "$cache_dir"

# packages.txt: one package per line, # for comments
docker run --rm --platform linux/amd64 \
  -v "$target_dir:/out" \
  -v "$cache_dir/apt-cache:/var/cache/apt" \
  ubuntu:24.04 bash -lc '
  export DEBIAN_FRONTEND=noninteractive
  echo "APT::Keep-Downloaded-Packages \"true\";" >/etc/apt/apt.conf.d/99keep
  rm -f /etc/apt/apt.conf.d/docker-clean
  apt-get update
  PKGS=$(grep -vE "^\s*#" /out/packages.txt | tr "\n" " ")
  apt-get install --download-only -y --no-install-recommends $PKGS
  cp /var/cache/apt/archives/*.deb /out/
'
endsnippet

snippet scoop_archive "download Windows Scoop packages for offline install"
#!/usr/bin/env bash
set -euxo pipefail

scoop_url="https://raw.githubusercontent.com/ScoopInstaller"
target_dir="./archives/scoop"
mkdir -p "$target_dir"

scoop_download() {
  local bucket="$1" app="$2" fixed_ver="${3:-}"
  local manifest=$(curl -sSL "$scoop_url/$bucket/refs/heads/master/bucket/$app.json")
  local version url

  if [[ -n "$fixed_ver" ]]; then
    version="$fixed_ver"
    url=$(echo "$manifest" | jq -r '.autoupdate.architecture["64bit"].url')
    url=${url//\$version/$fixed_ver}
  else
    version=$(echo "$manifest" | jq -r '.version')
    url=$(echo "$manifest" | jq -r '.architecture["64bit"].url // .url')
  fi

  local ext=$(echo "$url" | rev | cut -d. -f1 | rev)
  local target="$target_dir/$app-$version.$ext"
  [[ -f "$target" ]] && return
  curl -L -o "$target" "$url"
}

# scoop_download "Main" "7zip"
# scoop_download "Extras" "vscode"
# scoop_download "Java" "temurin21-jdk"
endsnippet
