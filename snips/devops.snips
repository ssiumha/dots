snippet scc "count lines of code; others: cloc, tokei"
scc .
endsnippet

snippet docker_swarm_deploy "init swarm + service create/update"
#!/bin/bash
set -e

if ! [ -x "$(command -v docker)" ]; then
  echo "Docker is not installed. Installing Docker..."
  sudo apt update
  sudo apt install -y docker.io
  sudo systemctl enable docker
  sudo systemctl start docker
  sudo usermod -aG docker "$(whoami)"
  echo 'Log out and log back in to apply the group change'
  exit 1
fi

if ! docker info | grep -q "Swarm: active"; then
  echo "Docker swarm is not initialized. Initializing Docker swarm..."
  docker swarm init
fi

SERVICE_NAME="my-service"

if docker service ls | grep -q "${SERVICE_NAME}"; then
  echo "Updating ${SERVICE_NAME}..."
  docker service update \
    --image my-service:latest \
    --update-parallelism 1 \
    --update-delay 10s \
    --update-failure-action rollback \
    "${SERVICE_NAME}"
else
  echo "Deploying ${SERVICE_NAME}..."
  docker service create \
    --name "${SERVICE_NAME}" \
    --replicas 2 \
    --update-delay 10s \
    --update-parallelism 1 \
    --update-failure-action rollback \
    my-service:latest
fi
endsnippet

snippet az_vm_run_command "execute script on Azure VM"
# Run a script on an Azure VM
az vm run-command invoke \
  --resource-group <rg-name> \
  --name <vm-name> \
  --command-id RunShellScript \
  --scripts "$(cat deploy.sh)"

# List run-commands
az vm run-command list \
  --resource-group <rg-name> \
  --location 'koreacentral' \
  --vm-name <vm-name> -o table

# Show result
az vm run-command show \
  --resource-group <rg-name> \
  --name <vm-name> \
  --command-id RunShellScript \
  --location 'koreacentral' -o json
endsnippet

snippet nexus_repo_api "create Nexus repository via REST API"
#!/usr/bin/env bash
set -euxo pipefail

NX_URL=${NX_URL:-"http://localhost:8081"}
NX_USER="admin"
NX_PASSWORD="password"

repo_exists() {
  curl -k -u "$NX_USER:$NX_PASSWORD" -s -o /dev/null -w "%{http_code}" \
    "$NX_URL/service/rest/v1/repositories/$1" | grep -q "200"
}

# npm proxy
repo_exists "npm-proxy" || \
curl -vk -u "$NX_USER:$NX_PASSWORD" -X POST \
  "$NX_URL/service/rest/v1/repositories/npm/proxy" \
  -H "Content-Type: application/json" \
  -d '{
    "name": "npm-proxy",
    "online": true,
    "storage": { "blobStoreName": "default", "strictContentTypeValidation": true },
    "proxy": { "remoteUrl": "https://registry.npmjs.org/", "contentMaxAge": -1, "metadataMaxAge": 1440 },
    "negativeCache": { "enabled": true, "timeToLive": 1440 },
    "httpClient": { "blocked": false, "autoBlock": true }
  }'

# apt proxy (Ubuntu noble)
repo_exists "apt-noble-proxy" || \
curl -vk -u "$NX_USER:$NX_PASSWORD" -X POST \
  "$NX_URL/service/rest/v1/repositories/apt/proxy" \
  -H "Content-Type: application/json" \
  -d '{
    "name": "apt-noble-proxy",
    "online": true,
    "storage": { "blobStoreName": "default", "strictContentTypeValidation": true },
    "apt": { "distribution": "noble", "flat": false },
    "proxy": { "remoteUrl": "http://archive.ubuntu.com/ubuntu/", "contentMaxAge": -1, "metadataMaxAge": 1440 },
    "negativeCache": { "enabled": true, "timeToLive": 1440 },
    "httpClient": { "blocked": false, "autoBlock": false }
  }'
endsnippet

snippet docker_image_archive "pull and save images for offline transfer"
#!/usr/bin/env bash
set -euxo pipefail

target_dir="./archives/images"
mkdir -p "$target_dir"

images=(
  "caddy:2"
  "sonatype/nexus3:latest"
  "registry:3"
  "ubuntu:24.04"
)

for image in "${images[@]}"; do
  image_filename=$(echo "$image" | tr '/:' '__')".tar"
  if [ -f "$target_dir/$image_filename" ]; then
    echo "Skipping $image (already saved)"
    continue
  fi
  docker pull --platform linux/amd64 "$image"
  docker save -o "$target_dir/$image_filename" "$image"
done
endsnippet

snippet caddy_internal_tls "Caddy reverse proxy with auto internal TLS"
# Caddyfile
{
  admin off
}

nexus.example.internal:8081 {
  tls internal
  reverse_proxy nexus:8081
}

registry.example.internal:5000 {
  tls internal
  reverse_proxy registry:5000
}

# PKI certs auto-generated at:
#   data/caddy/pki/authorities/local/root.crt
#   data/caddy/pki/authorities/local/root.key
#
# Install root CA:
#   Ubuntu: sudo cp root.crt /usr/local/share/ca-certificates/ && sudo update-ca-certificates
#   RHEL:   sudo cp root.crt /etc/pki/ca-trust/source/anchors/ && sudo update-ca-trust extract
#   Docker: sudo cp root.crt /etc/docker/certs.d/<host>:443/ca.crt && sudo systemctl restart docker
endsnippet

